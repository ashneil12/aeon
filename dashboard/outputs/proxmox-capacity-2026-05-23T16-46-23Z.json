{
  "root": "card_main",
  "state": {},
  "elements": {
    "card_main": {
      "type": "Card",
      "props": {
        "title": "proxmox-capacity"
      },
      "children": [
        "alert_status",
        "sep1",
        "heading_metrics",
        "grid_metrics",
        "sep2",
        "heading_runbook",
        "text_runbook"
      ]
    },
    "alert_status": {
      "type": "Alert",
      "props": {
        "title": "🟡 pve5 [OK→WATCH]",
        "message": "Disk local-lvm at 70.1% (up from 67.6%) — thin-pool crossed 70% threshold",
        "type": "warning"
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "heading_metrics": {
      "type": "Heading",
      "props": {
        "text": "pve5 Metrics",
        "level": "h2"
      }
    },
    "grid_metrics": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": "md"
      },
      "children": [
        "progress_disk",
        "progress_mem",
        "stat_load",
        "stat_vms"
      ]
    },
    "progress_disk": {
      "type": "Progress",
      "props": {
        "value": 70.1,
        "max": 100,
        "label": "Disk (local-lvm): 625.2/891.2 GB"
      }
    },
    "progress_mem": {
      "type": "Progress",
      "props": {
        "value": 53.5,
        "max": 100,
        "label": "Memory: 72.2/134.9 GB"
      }
    },
    "stat_load": {
      "type": "Stat",
      "props": {
        "label": "Load (5-min avg)",
        "value": "2.79 / 12 vCPU (0.23x)"
      }
    },
    "stat_vms": {
      "type": "Stat",
      "props": {
        "label": "VMs",
        "value": "43 / 48"
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "heading_runbook": {
      "type": "Heading",
      "props": {
        "text": "Runbook",
        "level": "h2"
      }
    },
    "text_runbook": {
      "type": "Text",
      "props": {
        "text": "Thin-pool crossed 70% on slow fill (not a load spike). Action: trim old snapshots/disks or rebalance. Headroom available: pve7 (41%) and pve3 (42%).",
        "variant": "body"
      }
    }
  }
}
